{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": ["dev", "test", "prod"],
      "metadata": {
        "description": "Environment name (dev, test, prod)"
      }
    },
    "aksClusterName": {
      "type": "string",
      "defaultValue": "[concat('aks-inspire-', parameters('environment'))]",
      "metadata": {
        "description": "Name of the AKS cluster"
      }
    },
    "acrName": {
      "type": "string",
      "defaultValue": "[concat('acrinspire', parameters('environment'))]",
      "metadata": {
        "description": "Name of the Azure Container Registry (must be globally unique, 5-50 alphanumeric characters)"
      }
    },
    "aksNodeCount": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "Number of nodes in the AKS cluster"
      }
    },
    "aksNodeVMSize": {
      "type": "string",
      "defaultValue": "Standard_B2s",
      "allowedValues": ["Standard_B2s", "Standard_D2s_v3", "Standard_D4s_v3"],
      "metadata": {
        "description": "VM size for AKS nodes"
      }
    },
    "kubernetesVersion": {
      "type": "string",
      "defaultValue": "1.27",
      "metadata": {
        "description": "Kubernetes version"
      }
    }
  },
  "variables": {
    "resourceTags": {
      "Environment": "[parameters('environment')]",
      "Application": "inspire-app",
      "ManagedBy": "ARM"
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-01-01-preview",
      "name": "[parameters('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": true
      },
      "tags": "[variables('resourceTags')]"
    },
    {
      "type": "Microsoft.ContainerService/managedClusters",
      "apiVersion": "2023-03-01",
      "name": "[parameters('aksClusterName')]",
      "location": "[parameters('location')]",
      "properties": {
        "kubernetesVersion": "[parameters('kubernetesVersion')]",
        "dnsPrefix": "[parameters('aksClusterName')]",
        "agentPoolProfiles": [
          {
            "name": "agentpool",
            "count": "[parameters('aksNodeCount')]",
            "vmSize": "[parameters('aksNodeVMSize')]",
            "osType": "Linux",
            "type": "VirtualMachineScaleSets",
            "enableNodePublicIP": false
          }
        ],
        "servicePrincipalProfile": {
          "clientId": "msi"
        },
        "addonProfiles": {
          "httpApplicationRouting": {
            "enabled": true
          }
        },
        "networkProfile": {
          "networkPlugin": "kubenet",
          "loadBalancerSku": "standard"
        }
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": "[variables('resourceTags')]",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(concat(resourceGroup().id, parameters('aksClusterName'), 'AcrPull'))]",
      "properties": {
        "roleDefinitionId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Authorization/roleDefinitions/', '7f951dcc-xxxx-xxxx-xxxx-xxxxxxxxxxxx')]",
        "principalId": "[reference(resourceId('Microsoft.ContainerService/managedClusters', parameters('aksClusterName')), '2023-03-01').identityProfile.kubeletidentity.objectId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerService/managedClusters', parameters('aksClusterName'))]"
      ]
    }
  ],
  "outputs": {
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(parameters('acrName')).loginServer]"
    },
    "aksClusterName": {
      "type": "string",
      "value": "[parameters('aksClusterName')]"
    },
    "aksClusterFqdn": {
      "type": "string",
      "value": "[reference(parameters('aksClusterName')).fqdn]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    }
  }
}